# =============================================================================
# App Template – environment example
# Copy to .env.local for local dev. Never commit secrets.
# All variables are validated at boot in packages/config (Zod schema).
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
APP_ENV=local                       # local | staging | production
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=debug                     # trace | debug | info | warn | error

# --- Database (App) ---------------------------------------------------------
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public
DATABASE_POOL_MAX=10

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Keycloak / Auth.js -----------------------------------------------------
# Keycloak issuer (Realm-URL), e.g. http://localhost:8080/realms/app
KEYCLOAK_ISSUER=http://localhost:8080/realms/app
KEYCLOAK_CLIENT_ID=app-web
KEYCLOAK_CLIENT_SECRET=replace-me
# 32+ random bytes, e.g. `openssl rand -base64 32`
AUTH_SECRET=replace-with-random-32-bytes
AUTH_URL=http://localhost:3000
# Set to true behind a reverse proxy (Caddy in prod) so auth.js trusts X-Forwarded-* headers
AUTH_TRUST_HOST=false

# --- Observability (OpenTelemetry) -----------------------------------------
# Empty value disables OTLP export (stack still runs, just no telemetry leaves the box).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=app-web
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# --- Feature flags (env-based stub) ----------------------------------------
FEATURE_AUDIT_LOG=false

# --- Worker -----------------------------------------------------------------
WORKER_CONCURRENCY=4
WORKER_HTTP_PORT=3100
# Used by the web app to proxy /admin/queues → worker's Bull Board.
# In Compose: http://worker:3100. In local dev: http://localhost:3100.
BULL_BOARD_INTERNAL_URL=http://localhost:3100
