# =============================================================================
# App Template – environment example
# Copy to .env (repo root) for production / customer installs, or to
# .env.local for the dev workflow (`make dev`). Never commit either.
#
# Two consumers:
#   1. Compose interpolates `${VAR:?required}` against this file at `up`
#      time. Missing keys = loud failure. (See deploy/compose/docker-compose.yml.)
#   2. The app processes (web + worker) load DATABASE_URL, AUTH_SECRET,
#      etc. as their own env. packages/config/src/env.ts validates them
#      via Zod at module load.
# =============================================================================

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development
APP_ENV=local                       # local | staging | production
APP_BASE_URL=http://localhost:3000
LOG_LEVEL=debug                     # trace | debug | info | warn | error

# --- Database (app) ---------------------------------------------------------
# Used by both the postgres-app container (USER/PASSWORD/DB) and the apps
# (DATABASE_URL). Keep the URL aligned with the parts.
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=app
POSTGRES_APP_DB=app
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public
DATABASE_POOL_MAX=10

# --- Database (Keycloak) ----------------------------------------------------
POSTGRES_KEYCLOAK_USER=keycloak
POSTGRES_KEYCLOAK_PASSWORD=keycloak
POSTGRES_KEYCLOAK_DB=keycloak

# --- Keycloak bootstrap admin ----------------------------------------------
# Used once on first start to create the master-realm admin. Replace the
# resulting account in the Keycloak UI immediately after first login.
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=replace-me

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Auth.js / Keycloak client ---------------------------------------------
KEYCLOAK_ISSUER=http://localhost:8080/realms/app
KEYCLOAK_CLIENT_ID=app-web
KEYCLOAK_CLIENT_SECRET=replace-me
AUTH_SECRET=replace-with-random-32-bytes        # `openssl rand -base64 32`
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=false                            # true behind a reverse proxy

# --- Observability (OpenTelemetry) -----------------------------------------
# Empty disables OTLP export (stack still runs, just no telemetry leaves the box).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=app-web
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# --- Grafana (obs profile) -------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me

# --- Feature flags (env-based stub) ----------------------------------------
FEATURE_AUDIT_LOG=false

# --- Worker -----------------------------------------------------------------
WORKER_CONCURRENCY=4
WORKER_HTTP_PORT=3100
# Used by the web app to proxy /admin/queues → worker's Bull Board.
# In Compose: http://worker:3100. In local dev: http://localhost:3100.
BULL_BOARD_INTERNAL_URL=http://localhost:3100

# --- Image registry + tag (production deploys only) ------------------------
# Customer installs pull pre-built images from these. Local dev / smoke
# build their own images via deploy/compose/docker-compose.build.yml.
REGISTRY=ghcr.io/your-org
IMAGE_TAG=v0.0.0

# --- Hostnames (Caddy auto-TLS) --------------------------------------------
APP_HOSTNAME=app.example.com
AUTH_HOSTNAME=auth.example.com
ACME_EMAIL=admin@example.com
