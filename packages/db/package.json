{
  "name": "@app/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./audit": "./src/audit.ts",
    "./types": "./generated/client.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate": "bunx --bun prisma generate",
    "migrate:dev": "bunx --bun prisma migrate dev",
    "migrate:deploy": "bunx --bun prisma migrate deploy",
    "migrate:reset": "bunx --bun prisma migrate reset",
    "seed": "bun run prisma/seed.ts",
    "studio": "bunx --bun prisma studio",
    "format": "bunx --bun prisma format"
  },
  "dependencies": {
    "@app/config": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "8.20.0"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "prisma": "7.8.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
