// effi-notes schema. Template-locked tables (User, AuditLog) are preserved
// as-is; the notes domain (Folder, Note, Tag, NoteTag, NoteHistory) is the
// customer-project extension.

generator client {
  provider     = "prisma-client"
  output       = "../generated"
  runtime      = "bun"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

/// Cached projection of an identity managed by Keycloak.
/// Source of truth for identity stays in Keycloak; this row is upserted on
/// first login and refreshed on subsequent logins (Phase 3 wires this).
model User {
  id               String            @id @default(cuid())
  keycloakSub      String            @unique
  email            String            @unique
  displayName      String?
  locale           String            @default("de")
  theme            String            @default("warm-paper")
  roles            String[]          @default([])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lastSeenAt       DateTime?
  auditLogs        AuditLog[]
  authoredNotes    Note[]            @relation("note_author")
  editedNotes      Note[]            @relation("note_last_editor")
  noteHistory      NoteHistory[]
  ownedFolders     Folder[]          @relation("folder_owner")
  sharesReceived   Share[]           @relation("share_grantee")
  sharesCreated    Share[]           @relation("share_creator")
  publicLinks      PublicLink[]      @relation("publiclink_creator")
  microsoftAccount MicrosoftAccount?
  appointmentLinks AppointmentLink[] @relation("appointmentlink_linker")

  @@index([email])
}

/// Append-only audit trail. Helper in `@app/db/audit` — never auto-wired,
/// callers decide which actions are auditable per customer project.
model AuditLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  subject    String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  @@index([occurredAt])
  @@index([actorId, occurredAt])
  @@index([action, occurredAt])
}

/// Folder for organising notes. Trees are formed by self-referencing parentId.
/// `position` is the sidebar ordering hint within a parent.
model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?  @relation("folder_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("folder_tree")
  notes     Note[]
  ownerId   String
  owner     User     @relation("folder_owner", fields: [ownerId], references: [id], onDelete: Restrict)
  shares    Share[]
  position  Int      @default(0)
  icon      String   @default("folder")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, position])
  @@index([ownerId])
}

/// A collaboratively-edited note. `yjsState` is the canonical document — the
/// CRDT snapshot the editor renders and the worker's snapshot processor keeps
/// up to date (see ADR 0022). `body` is a plain-text mirror of the doc kept
/// in sync by `PUT /api/notes/[id]/body` (the editor sends `editor.getText()`
/// every ~5 s); it powers full-text search, snippets, and read-only HTML
/// rendering for public links. It is NOT canonical markdown today —
/// re-renaming to e.g. `bodyText` or switching to true markdown would be a
/// breaking change deferred to its own ADR (QA review 2026-05-20, P2).
/// `searchVector` is a generated tsvector column added in the migration's raw
/// SQL block — Prisma sees it as Unsupported but it is queryable via
/// $queryRaw.
model Note {
  id           String                   @id @default(cuid())
  title        String
  body         String                   @default("")
  // Content-specific concurrency counter used by `PUT /api/notes/[id]/body`.
  // Incremented only when `body` is written through that route; title-only
  // PATCHes and worker Yjs snapshots leave it alone so they don't invalidate
  // an in-flight editor save (QA review 2026-05-20, P1).
  bodyVersion  Int                      @default(0)
  yjsState     Bytes?
  folderId     String?
  folder       Folder?                  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  authorId     String
  author       User                     @relation("note_author", fields: [authorId], references: [id])
  lastEditorId String?
  lastEditor   User?                    @relation("note_last_editor", fields: [lastEditorId], references: [id], onDelete: SetNull)
  archivedAt        DateTime?
  titleManuallySet  Boolean                  @default(false)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  tags         NoteTag[]
  history      NoteHistory[]
  assets       Asset[]
  shares       Share[]
  publicLink   PublicLink?
  appointmentLinks AppointmentLink[]
  searchVector Unsupported("tsvector")?

  @@index([folderId, updatedAt])
  @@index([archivedAt])
  @@index([authorId, updatedAt])
}

/// Free-form tag dictionary. Tags are global because tags are a shared vocabulary; note/folder access is
/// governed per-resource by the Share model (see ADR 0026).
model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String?
  notes     NoteTag[]
  createdAt DateTime  @default(now())
}

/// Join table for Note <-> Tag.
model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

/// Immutable snapshot of a note's body + Yjs state. Written by the snapshot
/// processor either every N updates or on session close. Read by the history
/// view.
model NoteHistory {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  yjsState  Bytes?
  createdAt DateTime @default(now())

  @@index([noteId, createdAt])
}

/// Asset kind. IMAGE is produced in sub-project A; PDF is declared now so
/// sub-project B needs no enum migration.
enum AssetKind {
  IMAGE
  PDF
}

/// A binary file embedded in a note. Bytes live in Postgres (`data`).
/// `searchVector` is a generated tsvector over filename + caption +
/// extractedText (added via raw SQL in the migration — Prisma sees it as
/// Unsupported but it is queryable via $queryRaw), so a note is findable
/// through its embedded assets. `authorId` is a plain column (audit actor);
/// no FK relation to keep the template `User` model untouched.
model Asset {
  id                 String                   @id @default(cuid())
  noteId             String
  note               Note                     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId           String
  kind               AssetKind
  contentType        String
  filename           String
  caption            String                   @default("")
  extractedText      String                   @default("")
  byteSize           Int
  data               Bytes
  previewImage       Bytes?
  previewContentType String?
  pageCount          Int?
  unreferencedSince  DateTime?
  createdAt          DateTime                 @default(now())
  searchVector       Unsupported("tsvector")?

  @@index([noteId])
  @@index([unreferencedSince])
}

/// View or edit access level for a Share.
enum ShareAccess {
  VIEW
  EDIT
}

/// An explicit grant of access to a single Note OR a single Folder.
/// Exactly one of noteId / folderId is set — enforced by a DB CHECK
/// constraint added in the migration's raw-SQL block.
model Share {
  id          String      @id @default(cuid())
  noteId      String?
  note        Note?       @relation(fields: [noteId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  granteeId   String
  grantee     User        @relation("share_grantee", fields: [granteeId], references: [id], onDelete: Cascade)
  access      ShareAccess
  expiresAt   DateTime?
  createdById String
  createdBy   User        @relation("share_creator", fields: [createdById], references: [id], onDelete: Cascade)
  seenAt      DateTime?
  createdAt   DateTime    @default(now())

  @@unique([noteId, granteeId])
  @@unique([folderId, granteeId])
  @@index([granteeId])
  @@index([noteId])
  @@index([folderId])
  @@index([expiresAt])
}

/// An explicit, account-less public link to a single Note (see ADR 0028).
/// Anyone holding `token` may VIEW the note read-only until `expiresAt` passes
/// or the row is deleted (revoke). At most one row per note — regenerating
/// replaces it. Public links never grant edit access and are not modelled as
/// `Share` rows because a public link has no grantee user.
model PublicLink {
  id          String    @id @default(cuid())
  token       String    @unique
  noteId      String    @unique
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation("publiclink_creator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([expiresAt])
}

/// Per-user Microsoft 365 integration (ADR 0031). 1:1 with User. The refresh
/// token is the only artefact that survives sign-out; access tokens are
/// fetched on demand via `lib/microsoft/tokens.ts` and never persisted.
/// Documented exception to the "no auth tokens in the DB" rule — Microsoft
/// has no equivalent of Keycloak's cookie-session.
model MicrosoftAccount {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String
  oid          String
  upn          String?
  refreshToken String   @db.Text
  scopes       String
  connectedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// A note's backlink to a Microsoft Graph calendar event (ADR 0031). Holds a
/// small NON-attendee snapshot (subject + start/end + webLink) so the chip
/// renders without a Graph round-trip and the search route can find notes by
/// appointment subject. Attendees are NEVER snapshotted — the popover live-
/// fetches them through the viewer's own M365 token.
model AppointmentLink {
  id         String    @id @default(cuid())
  noteId     String
  note       Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  eventId    String
  subject    String
  startsAt   DateTime?
  endsAt     DateTime?
  webLink    String?
  linkedById String
  linkedBy   User      @relation("appointmentlink_linker", fields: [linkedById], references: [id], onDelete: Cascade)
  linkedAt   DateTime  @default(now())

  @@unique([noteId, eventId])
  @@index([noteId])
  @@index([subject])
}
