// effi-notes schema. Template-locked tables (User, AuditLog) are preserved
// as-is; the notes domain (Folder, Note, Tag, NoteTag, NoteHistory) is the
// customer-project extension.

generator client {
  provider     = "prisma-client"
  output       = "../generated"
  runtime      = "bun"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

/// Cached projection of an identity managed by Keycloak.
/// Source of truth for identity stays in Keycloak; this row is upserted on
/// first login and refreshed on subsequent logins (Phase 3 wires this).
model User {
  id              String        @id @default(cuid())
  keycloakSub     String        @unique
  email           String        @unique
  displayName     String?
  locale          String        @default("de")
  roles           String[]      @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastSeenAt      DateTime?
  auditLogs       AuditLog[]
  authoredNotes   Note[]        @relation("note_author")
  editedNotes     Note[]        @relation("note_last_editor")
  noteHistory     NoteHistory[]

  @@index([email])
}

/// Append-only audit trail. Helper in `@app/db/audit` — never auto-wired,
/// callers decide which actions are auditable per customer project.
model AuditLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  subject    String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?

  @@index([occurredAt])
  @@index([actorId, occurredAt])
  @@index([action, occurredAt])
}

/// Folder for organising notes. Trees are formed by self-referencing parentId.
/// `position` is the sidebar ordering hint within a parent.
model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?  @relation("folder_tree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Folder[] @relation("folder_tree")
  notes     Note[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId, position])
}

/// A markdown-first note. `body` is the canonical markdown source. `yjsState`
/// is the most recent CRDT snapshot (written by the worker's snapshot
/// processor; see ADR 0022). `searchVector` is a generated tsvector column
/// added in the migration's raw SQL block — Prisma sees it as Unsupported but
/// it is queryable via $queryRaw.
model Note {
  id           String        @id @default(cuid())
  title        String
  body         String        @default("")
  yjsState     Bytes?
  folderId     String?
  folder       Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  authorId     String
  author       User          @relation("note_author", fields: [authorId], references: [id])
  lastEditorId String?
  lastEditor   User?         @relation("note_last_editor", fields: [lastEditorId], references: [id], onDelete: SetNull)
  archivedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tags         NoteTag[]
  history      NoteHistory[]
  assets       Asset[]
  searchVector Unsupported("tsvector")?

  @@index([folderId, updatedAt])
  @@index([archivedAt])
  @@index([authorId, updatedAt])
}

/// Free-form tag dictionary. Tags are global (not per-user) because the
/// sharing model in v1 is "all users see all notes".
model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  color     String?
  notes     NoteTag[]
  createdAt DateTime  @default(now())
}

/// Join table for Note <-> Tag.
model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
  @@index([tagId])
}

/// Immutable snapshot of a note's body + Yjs state. Written by the snapshot
/// processor either every N updates or on session close. Read by the history
/// view.
model NoteHistory {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  yjsState  Bytes?
  createdAt DateTime @default(now())

  @@index([noteId, createdAt])
}

/// Asset kind. IMAGE is produced in sub-project A; PDF is declared now so
/// sub-project B needs no enum migration.
enum AssetKind {
  IMAGE
  PDF
}

/// A binary file embedded in a note. Bytes live in Postgres (`data`).
/// `searchVector` is a generated tsvector over filename + caption +
/// extractedText (added via raw SQL in the migration — Prisma sees it as
/// Unsupported but it is queryable via $queryRaw), so a note is findable
/// through its embedded assets. `authorId` is a plain column (audit actor);
/// no FK relation to keep the template `User` model untouched.
model Asset {
  id            String    @id @default(cuid())
  noteId        String
  note          Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  authorId      String
  kind          AssetKind
  contentType   String
  filename      String
  caption       String    @default("")
  extractedText String    @default("")
  byteSize      Int
  data          Bytes
  createdAt     DateTime  @default(now())
  searchVector  Unsupported("tsvector")?

  @@index([noteId])
}
