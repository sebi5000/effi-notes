{
  "name": "app-template",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @app/web dev",
    "dev:worker": "bun --filter @app/worker dev",
    "build": "bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "lint": "biome lint .",
    "lint:next": "bun --filter @app/web lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "test": "bun --filter '*' test",
    "prepare": "lefthook install",
    "changeset": "bunx --bun changeset",
    "changeset:version": "bunx --bun changeset version",
    "changeset:publish": "bunx --bun changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/types": "20.5.0",
    "@types/bun": "1.3.13",
    "@types/node": "25.6.0",
    "lefthook": "2.1.6",
    "typescript": "6.0.3"
  }
}
